DATABASE_URL=postgresql://erp_admin:erp_secret_dev@localhost:5432/erp_dev
REDIS_URL=redis://localhost:6379
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800
PORT=3000

# ─── Batch 6: cross-cutting infrastructure (all OPTIONAL) ─────────────
# Every feature below self-disables when its variable is empty, so a bare
# Postgres+Redis dev box runs the whole app unchanged.

# PII / MFA secret encryption (AES-256-GCM). REQUIRED for HRM PII + MFA.
PII_ENCRYPTION_KEY=dev-pii-key-change-me-min-16-chars

# App base URL used in transactional-email links
APP_BASE_URL=http://localhost:3000

# Background jobs / cron (INF-001). Set CRON_ENABLED=false on extra instances.
CRON_ENABLED=true

# Caching (INF-007)
CACHE_ENABLED=true
CACHE_TTL_SEC=60

# RabbitMQ domain-event bus (INF-002). Empty = events stay in the outbox.
RABBITMQ_URL=
RABBITMQ_EXCHANGE=erp.events

# MinIO / S3 object storage (INF-003). Empty = file endpoints return 503.
S3_ENDPOINT=
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=erp-files
S3_PRESIGN_TTL_SEC=300

# Transactional email via Resend (INF-005). Empty = emails logged, not sent.
RESEND_API_KEY=
EMAIL_FROM=ERP <no-reply@example.com>

# Observability (INF-006)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
# Required in production: /metrics returns 403 (fail closed) when unset with NODE_ENV=production.
# Send via header only: `Authorization: Bearer <token>` or `x-metrics-token` (query string not accepted).
METRICS_TOKEN=
LOG_LEVEL=info

# Auth hardening (SEC-001)
MFA_ISSUER=ERP
PASSWORD_RESET_TTL_SEC=1800
EMAIL_VERIFY_TTL_SEC=86400
MFA_CHALLENGE_TTL_SEC=300

# ─── Batch 7: BI / OLAP (ADR-011, OPTIONAL) ──────────────────────────
# DuckDB column store for analytics. Empty = /bi endpoints return 503.
# ':memory:' for a throwaway dev store, or a file path to persist. Requires the
# optional `duckdb` package (npm i duckdb). ETL runs in the worker process.
DUCKDB_PATH=
