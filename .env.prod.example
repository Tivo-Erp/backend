# ──────────────────────────────────────────────────────────────
# ERP Backend — Production Environment Variables
# Copy this file to .env.prod and fill in real values.
# NEVER commit .env.prod to git.
#
# Usage:
#   cp .env.prod.example .env.prod
#   nano .env.prod              # fill in real values
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# ──────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────
# Host port the API is published on (container always listens on 3000 internally).
PORT=3000
# Host interface the API binds to. Default 127.0.0.1 = loopback only, so a
# reverse proxy (nginx) on the same host fronts it. Set 0.0.0.0 ONLY if there is
# no proxy and the network is firewalled — it exposes the API to the host's LAN.
APP_BIND_HOST=127.0.0.1

# ─── Database ────────────────────────────────────────────────
POSTGRES_DB=erp_prod
POSTGRES_USER=erp_admin
# REQUIRED — no default. Use a strong random password (min 32 chars).
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# Internal listen port (within erp-network only — NOT published to the host).
# DATABASE_URL is built from this automatically. Rarely needs changing.
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────
# Increase if you have many sessions / heavy caching load
REDIS_MAX_MEMORY=256mb
# Internal listen port (within erp-network only — NOT published to the host).
# REDIS_URL is built from this automatically. Rarely needs changing.
REDIS_PORT=6379

# ─── JWT (RS256) ──────────────────────────────────────────────
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800
# Paths to PEM key files on host (mounted as Docker secrets into /run/secrets/)
# Generate: mkdir -p keys && openssl genrsa -out keys/private.pem 2048 && openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_FILE=./keys/private.pem
JWT_PUBLIC_KEY_FILE=./keys/public.pem

# ─── Auth Security ────────────────────────────────────────────
# Max failed login attempts before account lockout
AUTH_MAX_FAILED_ATTEMPTS=5
# Lockout duration in seconds (1800 = 30 minutes)
AUTH_LOCK_DURATION_SEC=1800

# ─── PII / MFA secret encryption (REQUIRED in prod) ──────────
# AES-256-GCM master passphrase (min 16 chars). Encrypts HRM PII + MFA secrets.
# Generate: openssl rand -base64 32   — rotate by re-encrypting, never reuse dev keys.
PII_ENCRYPTION_KEY=CHANGE_ME_MIN_16_CHARS

# ─── Hardening / CORS / Swagger ──────────────────────────────
NODE_ENV=production
# Comma-separated allowed browser origins (no trailing slash)
CORS_ORIGINS=https://app.example.com
# Swagger is OFF in production unless explicitly enabled
SWAGGER_ENABLED=false
# Public URL of THIS API as seen by the browser (behind WAF / reverse proxy).
# Used to label a server entry in Swagger UI's "Try it out". Optional — the docs
# also expose a relative "/" server that auto-targets the current origin.
SWAGGER_SERVER_URL=https://dev-erp-api.maxtot.com
APP_BASE_URL=https://app.example.com

# ─── Batch 6 infrastructure (SEC-001 / INF-001..007) ─────────
# Background worker + cron. Run ONE worker via: npm run start:worker
CRON_ENABLED=true
CACHE_ENABLED=true
CACHE_TTL_SEC=60

# RabbitMQ domain-event bus (INF-002). Empty RABBITMQ_URL = events stay buffered
# in the outbox. Credentials for the bundled rabbitmq container.
# RABBITMQ_DEFAULT_PASS is REQUIRED — keep RABBITMQ_URL in sync with it.
RABBITMQ_DEFAULT_USER=erp
RABBITMQ_DEFAULT_PASS=CHANGE_ME
# Internal AMQP port (within erp-network only — NOT published to the host).
# If you change it, the port in RABBITMQ_URL below MUST match.
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://erp:CHANGE_ME@rabbitmq:5672
RABBITMQ_EXCHANGE=erp.events

# MinIO / S3 object storage (INF-003). Empty = file endpoints return 503.
S3_ENDPOINT=minio.example.com
S3_PORT=443
S3_USE_SSL=true
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=erp-files
S3_PRESIGN_TTL_SEC=300

# Transactional email via Resend (INF-005). Empty = emails are logged, not sent.
RESEND_API_KEY=
EMAIL_FROM=ERP <no-reply@example.com>

# Observability (INF-006)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Protect GET /metrics behind a shared token (Authorization: Bearer / ?token=)
METRICS_TOKEN=CHANGE_ME
LOG_LEVEL=info

# Auth hardening (SEC-001)
MFA_ISSUER=ERP
PASSWORD_RESET_TTL_SEC=1800
EMAIL_VERIFY_TTL_SEC=86400
MFA_CHALLENGE_TTL_SEC=300

# ─── Batch 7: BI / OLAP (ADR-011, OPTIONAL) ──────────────────────────
# DuckDB analytics store. Empty = /bi endpoints return 503. Requires `duckdb`.
# MUST live under /app/data — that path is backed by the `duckdbdata` named
# volume, so the cube survives `up -d --build`. Any other path is on the
# container's ephemeral layer and is LOST on every rebuild.
DUCKDB_PATH=/app/data/erp.duckdb
# DUCKDB_READONLY is set PER SERVICE in docker-compose.prod.yml (app=true,
# worker=false) so the two processes share one cube file safely — do not set it
# here (a global value would make both processes read-only or both read-write).

# ─── Container resource limits (OPTIONAL — sensible defaults in compose) ─────
# Raise APP_MEM_LIMIT if BI/OLAP queries get OOM-killed; raise WORKER_MEM_LIMIT
# for heavy ETL. Format: "1G", "1536M", cpus as a string like "1.5".
# APP_MEM_LIMIT=1G
# APP_CPU_LIMIT=1.0
# WORKER_MEM_LIMIT=768M
# WORKER_CPU_LIMIT=0.5
