generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// PLATFORM (No RLS - cross-tenant)
// ============================================================

model Plan {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(50)
  name          String   @db.VarChar(200)
  description   String?  @db.Text
  maxUsers      Int?
  priceMonthly  Decimal  @default(0) @db.Decimal(15, 2)
  priceYearly   Decimal  @default(0) @db.Decimal(15, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
  features      PlanFeature[]

  @@map("plans")
}

model PlanFeature {
  id         String  @id @default(uuid()) @db.Uuid
  planId     String  @db.Uuid
  featureKey String  @db.VarChar(100)
  isEnabled  Boolean @default(false)

  plan Plan @relation(fields: [planId], references: [id])

  @@unique([planId, featureKey])
  @@map("plan_features")
}

// ============================================================
// TENANT CORE (RLS enabled)
// ============================================================

model Tenant {
  id           String   @id @default(uuid()) @db.Uuid
  slug         String   @unique @db.VarChar(63)
  name         String   @db.VarChar(255)
  legalName    String?  @db.VarChar(255)
  taxCode      String?  @db.VarChar(20)
  logoUrl      String?  @db.Text
  timezone     String   @default("Asia/Ho_Chi_Minh") @db.VarChar(50)
  locale       String   @default("vi-VN") @db.VarChar(10)
  baseCurrency String   @default("VND") @db.VarChar(3)
  status       String   @default("pending") @db.VarChar(20)
  settings     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users         User[]
  branches      Branch[]
  roles         Role[]
  subscriptions Subscription[]

  @@map("tenants")
}

model Subscription {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  planId           String    @db.Uuid
  status           String    @default("trialing") @db.VarChar(20)
  currentPeriodEnd DateTime?
  trialEndDate     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model Branch {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  code           String   @db.VarChar(20)
  name           String   @db.VarChar(255)
  address        String?  @db.Text
  city           String?  @db.VarChar(100)
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(255)
  isHeadquarters Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@map("branches")
}

model User {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  email            String    @db.VarChar(255)
  passwordHash     String    @db.VarChar(255)
  firstName        String    @db.VarChar(100)
  lastName         String    @db.VarChar(100)
  avatarUrl        String?   @db.Text
  status           String    @default("invited") @db.VarChar(20)
  mfaEnabled       Boolean   @default(false)
  mfaSecret        String?   @db.VarChar(255)
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  lastLoginIp      String?   @db.VarChar(45)
  isSuperAdmin     Boolean   @default(false)
  emailVerifiedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  userRoles UserRole[]

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique @db.VarChar(100)
  module      String @db.VarChar(50)
  description String @db.VarChar(255)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String @id @default(uuid()) @db.Uuid
  roleId       String @db.Uuid
  permissionId String @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  roleId String @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  // SEC: only the SHA-256 hex hash of the refresh token is stored.
  tokenHash    String    @unique @db.VarChar(64)
  // SEC-001 rotation family: all tokens minted from one login share a familyId;
  // replaying a rotated (revoked) token lets us revoke the whole family.
  familyId     String    @default(uuid()) @db.Uuid
  replacedById String?   @db.Uuid
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// SEC-001: single-use, hashed tokens for password reset, email verification
// and the MFA login challenge. Only the SHA-256 hash is persisted.
model AuthToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  type      String    @db.VarChar(30) // password_reset, email_verify, mfa_challenge
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, type])
  @@map("auth_tokens")
}

// INF-002: transactional outbox. Written inside the business mutation's
// transaction; drained to RabbitMQ by the outbox dispatcher.
model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  aggregateType String    @db.VarChar(50)
  aggregateId   String    @db.VarChar(64)
  eventType     String    @db.VarChar(100)
  payload       Json
  status        String    @default("pending") @db.VarChar(20) // pending, processing, published, failed
  attempts      Int       @default(0)
  createdAt     DateTime  @default(now())
  publishedAt   DateTime?
  claimedAt     DateTime? // set when a dispatcher claims the row (status=processing); stale claims are reclaimed

  @@index([status, createdAt])
  @@index([tenantId])
  @@map("outbox_events")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  userId     String?  @db.Uuid
  action     String   @db.VarChar(50)
  module     String   @db.VarChar(50)
  entityType String?  @db.VarChar(100)
  entityId   String?  @db.Uuid
  changes    Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, module])
  @@map("audit_logs")
}

model DocumentSequence {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @db.Uuid
  documentType  String  @db.VarChar(20)
  prefix        String  @db.VarChar(10)
  separator     String  @default("-") @db.VarChar(5)
  includeYear   Boolean @default(true)
  yearFormat    String  @default("YYYY") @db.VarChar(10)
  padding       Int     @default(5)
  lastNumber    Int     @default(0)
  lastResetYear Int?
  resetYearly   Boolean @default(true)
  branchId      String? @db.Uuid

  @@unique([tenantId, documentType, branchId])
  @@map("document_sequences")
}

// ============================================================
// MASTER DATA (M-MAT)  — Batch 2
// ============================================================

model ItemCategory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  name      String   @db.VarChar(200)
  parentId  String?  @db.Uuid
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryTree")
  items    Item[]

  @@unique([tenantId, name])
  @@map("item_categories")
}

model Item {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  sku              String   @db.VarChar(100)
  name             String   @db.VarChar(500)
  description      String?  @db.Text
  categoryId       String?  @db.Uuid
  itemType         String   @db.VarChar(30) // product, raw_material, semi_finished, service, consumable
  baseUom          String   @db.VarChar(20)
  weight           Decimal? @db.Decimal(10, 4)
  isBatchTracked   Boolean  @default(false)
  isSerialTracked  Boolean  @default(false)
  isPurchasable    Boolean  @default(true)
  isSellable       Boolean  @default(true)
  minStockLevel    Decimal? @db.Decimal(15, 4)
  safetyStock      Decimal? @db.Decimal(15, 4)
  leadTimeDays     Int?
  status           String   @default("draft") @db.VarChar(20)
  customAttributes Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  category          ItemCategory?      @relation(fields: [categoryId], references: [id])
  inventoryBalances InventoryBalance[]
  bomParent         BOM[]              @relation("BOMParent")
  bomLines          BOMLine[]          @relation("BOMLineComponent")
  lots              Lot[]

  @@unique([tenantId, sku])
  @@index([tenantId, status])
  @@index([tenantId, itemType])
  @@map("items")
}

model BOM {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  itemId    String   @db.Uuid
  name      String   @db.VarChar(200)
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item  Item      @relation("BOMParent", fields: [itemId], references: [id])
  lines BOMLine[]

  @@unique([tenantId, itemId, version])
  @@map("boms")
}

model BOMLine {
  id              String  @id @default(uuid()) @db.Uuid
  bomId           String  @db.Uuid
  componentItemId String  @db.Uuid
  quantityPerUnit Decimal @db.Decimal(15, 6)
  uom             String  @db.VarChar(20)
  scrapPct        Decimal @default(0) @db.Decimal(5, 2)
  sortOrder       Int     @default(0)

  bom           BOM  @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentItem Item @relation("BOMLineComponent", fields: [componentItemId], references: [id])

  @@map("bom_lines")
}

// ============================================================
// WAREHOUSE (M-WMS)  — Batch 2
// ============================================================

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  code      String   @db.VarChar(20)
  name      String   @db.VarChar(200)
  branchId  String?  @db.Uuid
  address   String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zones             Zone[]
  inventoryBalances InventoryBalance[]

  @@unique([tenantId, code])
  @@map("warehouses")
}

model Zone {
  id          String @id @default(uuid()) @db.Uuid
  warehouseId String @db.Uuid
  code        String @db.VarChar(20)
  name        String @db.VarChar(200)
  zoneType    String @db.VarChar(30) // bulk, pick, staging, quarantine, dispatch, receiving, storage

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  bins      Bin[]

  @@unique([warehouseId, code])
  @@map("zones")
}

model Bin {
  id          String   @id @default(uuid()) @db.Uuid
  zoneId      String   @db.Uuid
  barcode     String   @db.VarChar(50)
  label       String?  @db.VarChar(100)
  binType     String   @db.VarChar(20) // general, pick, bulk, pallet, refrigerated
  maxWeightKg Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)

  zone              Zone               @relation(fields: [zoneId], references: [id])
  inventoryBalances InventoryBalance[]
  stockMovements    StockMovement[]

  @@unique([zoneId, barcode])
  @@map("bins")
}

// ============================================================
// INVENTORY (M-INV)  — Batch 2
// ============================================================

model InventoryBalance {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  itemId           String   @db.Uuid
  warehouseId      String   @db.Uuid
  variantId        String?  @db.Uuid
  binId            String?  @db.Uuid
  lotId            String?  @db.Uuid
  quantityOnHand   Decimal  @default(0) @db.Decimal(15, 4)
  quantityReserved Decimal  @default(0) @db.Decimal(15, 4)
  costPerUnit      Decimal  @default(0) @db.Decimal(15, 4)
  uom              String   @db.VarChar(20)
  updatedAt        DateTime @updatedAt

  item      Item       @relation(fields: [itemId], references: [id])
  warehouse Warehouse  @relation(fields: [warehouseId], references: [id])
  bin       Bin?       @relation(fields: [binId], references: [id])
  lot       Lot?       @relation(fields: [lotId], references: [id])

  @@unique([tenantId, itemId, warehouseId, variantId, binId, lotId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, itemId])
  @@map("inventory_balances")
}

model StockMovement {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  itemId        String   @db.Uuid
  warehouseId   String   @db.Uuid
  movementType  String   @db.VarChar(30) // grn_receipt, sales_shipment, adjustment, transfer_in, transfer_out, manufacturing_consumption, manufacturing_output
  direction     String   @db.VarChar(3) // IN, OUT
  quantity      Decimal  @db.Decimal(15, 4)
  uom           String   @db.VarChar(20)
  costPerUnit   Decimal? @db.Decimal(15, 4)
  referenceType String?  @db.VarChar(50) // PurchaseOrder, SalesOrder
  referenceId   String?  @db.Uuid
  binId         String?  @db.Uuid
  lotId         String?  @db.Uuid
  notes         String?  @db.Text
  createdBy     String   @db.Uuid
  createdAt     DateTime @default(now())

  bin Bin? @relation(fields: [binId], references: [id])
  lot Lot? @relation(fields: [lotId], references: [id])

  @@index([tenantId, itemId, createdAt])
  @@index([tenantId, warehouseId, createdAt])
  @@map("stock_movements")
}

model Lot {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @db.Uuid
  lotNumber  String    @db.VarChar(100)
  itemId     String    @db.Uuid
  expiryDate DateTime?
  status     String    @default("active") @db.VarChar(20)
  createdAt  DateTime  @default(now())

  item              Item               @relation(fields: [itemId], references: [id])
  inventoryBalances InventoryBalance[]
  stockMovements    StockMovement[]

  @@unique([tenantId, lotNumber])
  @@map("lots")
}

// ============================================================
// SUPPLIERS + CUSTOMERS  — Batch 3 (M-PUR / M-SAL)
// ============================================================

model Supplier {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  code             String   @db.VarChar(20)
  name             String   @db.VarChar(255)
  legalName        String?  @db.VarChar(255)
  taxCode          String?  @db.VarChar(20)
  contactName      String?  @db.VarChar(200)
  email            String?  @db.VarChar(255)
  phone            String?  @db.VarChar(20)
  address          String?  @db.Text
  creditLimit      Decimal  @default(0) @db.Decimal(15, 2)
  creditUsed       Decimal  @default(0) @db.Decimal(15, 2)
  paymentTermsDays Int      @default(30)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@map("suppliers")
}

model Customer {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  code             String   @db.VarChar(20)
  name             String   @db.VarChar(255)
  legalName        String?  @db.VarChar(255)
  taxCode          String?  @db.VarChar(20)
  contactName      String?  @db.VarChar(200)
  email            String?  @db.VarChar(255)
  phone            String?  @db.VarChar(20)
  address          String?  @db.Text
  creditLimit      Decimal  @default(0) @db.Decimal(15, 2)
  creditUsed       Decimal  @default(0) @db.Decimal(15, 2)
  paymentTermsDays Int      @default(30)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  salesOrders SalesOrder[]

  @@unique([tenantId, code])
  @@map("customers")
}

// ============================================================
// PURCHASE ORDERS  — Batch 3 (M-PUR)
// ============================================================

model PurchaseOrder {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  poNumber         String    @db.VarChar(30)
  supplierId       String    @db.Uuid
  warehouseId      String    @db.Uuid
  branchId         String?   @db.Uuid
  status           String    @default("draft") @db.VarChar(30)
  orderDate        DateTime  @default(now())
  expectedDate     DateTime?
  paymentTermsDays Int       @default(30)
  currency         String    @default("VND") @db.VarChar(3)
  subTotal         Decimal   @default(0) @db.Decimal(15, 2)
  discountAmount   Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount        Decimal   @default(0) @db.Decimal(15, 2)
  grandTotal       Decimal   @default(0) @db.Decimal(15, 2)
  notes            String?   @db.Text
  approvedBy       String?   @db.Uuid
  approvedAt       DateTime?
  createdBy        String    @db.Uuid
  updatedBy        String?   @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  lines    PurchaseOrderLine[]
  grns     GoodsReceipt[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id          String  @id @default(uuid()) @db.Uuid
  poId        String  @db.Uuid
  itemId      String  @db.Uuid
  variantId   String? @db.Uuid
  description String? @db.VarChar(500)
  quantity    Decimal @db.Decimal(15, 4)
  receivedQty Decimal @default(0) @db.Decimal(15, 4)
  uom         String  @db.VarChar(20)
  unitPrice   Decimal @db.Decimal(15, 4)
  discountPct Decimal @default(0) @db.Decimal(5, 2)
  taxRateId   String? @db.Uuid
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal @db.Decimal(15, 2)
  sortOrder   Int     @default(0)

  po PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
  @@map("purchase_order_lines")
}

model GoodsReceipt {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  grnNumber   String   @db.VarChar(30)
  poId        String   @db.Uuid
  warehouseId String   @db.Uuid
  receiptDate DateTime @default(now())
  notes       String?  @db.Text
  createdBy   String   @db.Uuid
  createdAt   DateTime @default(now())

  po    PurchaseOrder      @relation(fields: [poId], references: [id])
  lines GoodsReceiptLine[]

  @@unique([tenantId, grnNumber])
  @@index([tenantId, poId])
  @@map("goods_receipts")
}

model GoodsReceiptLine {
  id          String  @id @default(uuid()) @db.Uuid
  grnId       String  @db.Uuid
  poLineId    String  @db.Uuid
  itemId      String  @db.Uuid
  receivedQty Decimal @db.Decimal(15, 4)
  binId       String? @db.Uuid
  lotId       String? @db.Uuid
  uom         String  @db.VarChar(20)

  grn GoodsReceipt @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@index([grnId])
  @@map("goods_receipt_lines")
}

// ============================================================
// SALES ORDERS  — Batch 3 (M-SAL)
// ============================================================

model SalesOrder {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  soNumber       String    @db.VarChar(30)
  customerId     String    @db.Uuid
  warehouseId    String    @db.Uuid
  branchId       String?   @db.Uuid
  status         String    @default("draft") @db.VarChar(30)
  orderDate      DateTime  @default(now())
  deliveryDate   DateTime?
  currency       String    @default("VND") @db.VarChar(3)
  subTotal       Decimal   @default(0) @db.Decimal(15, 2)
  discountAmount Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal   @default(0) @db.Decimal(15, 2)
  grandTotal     Decimal   @default(0) @db.Decimal(15, 2)
  notes          String?   @db.Text
  approvedBy     String?   @db.Uuid
  approvedAt     DateTime?
  createdBy      String    @db.Uuid
  updatedBy      String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  customer Customer         @relation(fields: [customerId], references: [id])
  lines    SalesOrderLine[]

  @@unique([tenantId, soNumber])
  @@index([tenantId, status])
  @@map("sales_orders")
}

model SalesOrderLine {
  id          String  @id @default(uuid()) @db.Uuid
  soId        String  @db.Uuid
  itemId      String  @db.Uuid
  variantId   String? @db.Uuid
  quantity    Decimal @db.Decimal(15, 4)
  shippedQty  Decimal @default(0) @db.Decimal(15, 4)
  uom         String  @db.VarChar(20)
  unitPrice   Decimal @db.Decimal(15, 4)
  discountPct Decimal @default(0) @db.Decimal(5, 2)
  taxRateId   String? @db.Uuid
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal @db.Decimal(15, 2)
  sortOrder   Int     @default(0)

  so SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)

  @@index([soId])
  @@map("sales_order_lines")
}

// ============================================================
// FINANCE  — Batch 3 (M-FIN)
// ============================================================

model ChartOfAccount {
  id            String  @id @default(uuid()) @db.Uuid
  tenantId      String  @db.Uuid
  accountCode   String  @db.VarChar(20)
  accountName   String  @db.VarChar(255)
  accountType   String  @db.VarChar(20) // asset, liability, equity, revenue, expense
  parentCode    String? @db.VarChar(20)
  isGroup       Boolean @default(false)
  isActive      Boolean @default(true)
  normalBalance String  @db.VarChar(10) // debit, credit

  @@unique([tenantId, accountCode])
  @@index([tenantId, accountType])
  @@map("chart_of_accounts")
}

model FiscalPeriod {
  id       String    @id @default(uuid()) @db.Uuid
  tenantId String    @db.Uuid
  year     Int
  month    Int
