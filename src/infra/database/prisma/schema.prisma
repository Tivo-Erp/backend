model SupportTicket {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @db.Uuid
  ticketNumber      String    @db.VarChar(30)
  customerId        String    @db.Uuid
  subject           String    @db.VarChar(500)
  description       String?   @db.Text
  priority          String    @default("medium") @db.VarChar(20) // low, medium, high, critical
  status            String    @default("open") @db.VarChar(20) // open, in_progress, waiting_customer, resolved, closed, reopened
  category          String?   @db.VarChar(50)
  assignedTo        String?   @db.Uuid
  slaDueAt          DateTime?
  slaEscalatedAt    DateTime? // watermark: set once when SLA-breach escalation has fired for this ticket
  firstResponseAt   DateTime?
  resolvedAt        DateTime?
  satisfactionScore Int?
  createdBy         String    @db.Uuid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  comments TicketComment[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@map("support_tickets")
}

model TicketComment {
  id         String   @id @default(uuid()) @db.Uuid
  ticketId   String   @db.Uuid
  body       String   @db.Text
  isInternal Boolean  @default(false)
  createdBy  String   @db.Uuid
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_comments")
}

// ============================================================
// PROJECT MANAGEMENT (M-PMO)  — Batch 5
// ============================================================

model Project {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  code          String    @db.VarChar(30)
  name          String    @db.VarChar(255)
  description   String?   @db.Text
  customerId    String?   @db.Uuid
  managerId     String?   @db.Uuid
  branchId      String?   @db.Uuid
  status        String    @default("planning") @db.VarChar(20) // planning, active, on_hold, completed, cancelled
  priority      String    @default("normal") @db.VarChar(20) // normal, high, urgent
  startDate     DateTime
  targetEndDate DateTime?
  actualEndDate DateTime?
  budget        Decimal   @default(0) @db.Decimal(19, 4)
  currency      String    @default("VND") @db.VarChar(3)
  progressPct   Int       @default(0)
  createdBy     String    @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  members    ProjectMember[]
  tasks      ProjectTask[]
  milestones Milestone[]
  timesheets Timesheet[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  userId    String   @db.Uuid
  role      String   @default("member") @db.VarChar(20) // manager, member, viewer
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectTask {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  projectId      String    @db.Uuid
  parentId       String?   @db.Uuid
  title          String    @db.VarChar(500)
  description    String?   @db.Text
  assignedTo     String?   @db.Uuid
  status         String    @default("backlog") @db.VarChar(20) // backlog, todo, in_progress, review, done
  priority       String    @default("medium") @db.VarChar(20) // low, medium, high, critical
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Decimal?  @db.Decimal(8, 2)
  actualHours    Decimal?  @db.Decimal(8, 2)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId, status])
  @@map("project_tasks")
}

model Milestone {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  projectId   String    @db.Uuid
  name        String    @db.VarChar(255)
  dueDate     DateTime
  completedAt DateTime?
  sortOrder   Int       @default(0)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
  @@map("milestones")
}

model Timesheet {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  employeeId  String    @db.Uuid
  projectId   String    @db.Uuid
  taskId      String?   @db.Uuid
  logDate     DateTime  @db.Date
  hours       Decimal   @db.Decimal(5, 2)
  description String?   @db.Text
  billable    Boolean   @default(true)
  status      String    @default("draft") @db.VarChar(20) // draft, submitted, approved, rejected
  approvedBy  String?   @db.Uuid
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@index([tenantId, employeeId, logDate])
  @@index([tenantId, projectId])
  @@map("timesheets")
}

// ============================================================
// SHIPPING & LOGISTICS (M-SHP)  — Batch 7
// ============================================================

model Carrier {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  code            String   @db.VarChar(30) // GHN, GHTK, VNPOST, DHL
  name            String   @db.VarChar(200)
  apiEndpoint     String?  @db.Text
  apiKeyEncrypted String?  @db.Text // encrypted via PiiCrypto (ADR-007)
  webhookSecret   String?  @db.VarChar(255) // HMAC secret for inbound tracking webhooks
  config          Json? // defaultServiceType, autoLabelPrint, pickupSchedule, supportedRegions[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shipments     Shipment[]
  deliveryNotes DeliveryNote[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("carriers")
}

model Shipment {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @db.Uuid
  shipmentNumber    String    @db.VarChar(30)
  dnId              String    @unique @db.Uuid
  carrierId         String    @db.Uuid
  trackingNumber    String?   @db.VarChar(100)
  shippingLabelKey  String?   @db.Text // MinIO object key ({tenantId}/shp/{shipmentId}/...)
  status            String    @default("created") @db.VarChar(30) // created,label_printed,picked_up,in_transit,out_for_delivery,delivered,failed,returned
  serviceType       String?   @db.VarChar(50)
  weightKg          Decimal?  @db.Decimal(10, 3)
  lengthCm          Decimal?  @db.Decimal(10, 2)
  widthCm           Decimal?  @db.Decimal(10, 2)
  heightCm          Decimal?  @db.Decimal(10, 2)
  isCod             Boolean   @default(false)
  codAmount         Decimal?  @db.Decimal(19, 4)
  shippingCost      Decimal?  @db.Decimal(19, 4)
  trackingToken     String?   @unique @db.VarChar(64) // opaque token for the public tracking link
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  failureReason     String?   @db.VarChar(255)
  createdBy         String    @db.Uuid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  carrier        Carrier         @relation(fields: [carrierId], references: [id], onDelete: Restrict)
  dn             DeliveryNote    @relation(fields: [dnId], references: [id], onDelete: Restrict)
  trackingEvents TrackingEvent[]

  @@unique([tenantId, shipmentNumber])
  @@unique([tenantId, trackingNumber])
  @@index([tenantId, status])
  @@index([carrierId])
  @@map("shipments")
}

model TrackingEvent {
  id          String   @id @default(uuid()) @db.Uuid
  shipmentId  String   @db.Uuid
  status      String   @db.VarChar(30)
  description String?  @db.Text
  location    String?  @db.VarChar(255)
  eventTime   DateTime
  rawData     Json?
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, eventTime])
  @@map("tracking_events")
}
